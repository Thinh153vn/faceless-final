	/**
	 * お気に入り追加・削除の非同期処理 (AJAX Toggle)
	 */
	@RequestMapping(path = "/client/favorite/toggleAjax", method = RequestMethod.POST)
	@ResponseBody // Rất quan trọng: Báo cho Spring Boot trả về chuỗi Text, không chuyển trang HTML
	public String toggleAjax(@RequestParam("itemId") Integer itemId) {
		UserBean user = (UserBean) session.getAttribute("user");
		if (user == null) {
			return "UNAUTHORIZED"; // Chưa đăng nhập
		}

		// Kiểm tra trạng thái hiện tại trong DB
		Favorite existFavorite = favoriteRepository.findByUserIdAndItemId(user.getId(), itemId);
		
		if (existFavorite != null) {
			// Đã có -> Thực hiện XÓA
			favoriteRepository.delete(existFavorite);
			return "REMOVED";
		} else {
			// Chưa có -> Thực hiện THÊM
			Favorite favorite = new Favorite();
			favorite.setUserId(user.getId());
			favorite.setItemId(itemId);
			favorite.setInsertDate(new Date(System.currentTimeMillis()));
			favoriteRepository.save(favorite);
			return "ADDED";
		}
	}


