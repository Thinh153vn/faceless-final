/**
	 * お気に入り追加処理
	 */
	@RequestMapping(path = "/client/favorite/add", method = RequestMethod.POST)
	public String addFavorite(@RequestParam(name = "itemId", required = false) Integer itemId, 
			@RequestParam(name = "id", required = false) Integer id) {
		
		UserBean user = (UserBean) session.getAttribute("user");
		if (user == null) {
			return "redirect:/login";
		}
		
		// Lấy đúng ID sản phẩm từ View truyền lên
		Integer targetItemId = (itemId != null) ? itemId : id;
		if (targetItemId == null) {
			return "redirect:/client/favorite/list";
		}

		// SỬA LỖI: Dùng targetItemId thay vì itemId
		Favorite existFavorite = favoriteRepository.findByUserIdAndItemId(user.getId(), targetItemId);
		if (existFavorite == null) {
			Favorite favorite = new Favorite();
			favorite.setUserId(user.getId());
			favorite.setItemId(targetItemId); // SỬA LỖI: Dùng targetItemId
			favorite.setInsertDate(new Date(System.currentTimeMillis()));
			favoriteRepository.save(favorite);
		}

		return "redirect:/client/favorite/list";
	}

