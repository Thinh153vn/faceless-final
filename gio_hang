package jp.co.sss.shop.controller.client.basket;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Controller;
import org.springframework.ui.Model;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestMethod;
import jakarta.servlet.http.HttpSession;

import java.util.List;
import java.util.ArrayList;

import jp.co.sss.shop.bean.BasketBean;
import jp.co.sss.shop.entity.Item;
import jp.co.sss.shop.repository.ItemRepository;

@Controller
public class ClientBasketController {

    @Autowired
    HttpSession session;

    @Autowired
    ItemRepository itemRepository;

    /**
     * カゴ一覧表示 (Hiển thị Giỏ hàng)
     */
    @RequestMapping(path = "/client/basket/list", method = RequestMethod.GET)
    public String list(Model model) {
        @SuppressWarnings("unchecked")
        List<BasketBean> basketList = (List<BasketBean>) session.getAttribute("basketList");
        
        if (basketList == null) {
            basketList = new ArrayList<>();
        }
        
        model.addAttribute("basketList", basketList);
        return "client/basket/list"; 
    }

    /**
     * カゴへ追加 (Thêm vào Giỏ hàng)
     */
    @RequestMapping(path = "/client/basket/add", method = RequestMethod.POST)
    public String add(Integer itemId) {
        @SuppressWarnings("unchecked")
        List<BasketBean> basketList = (List<BasketBean>) session.getAttribute("basketList");
        if (basketList == null) {
            basketList = new ArrayList<>();
        }

        // Lấy thông tin Item từ DB để gán vào BasketBean
        Item item = itemRepository.findById(itemId).orElse(null);
        if (item == null) {
            return "redirect:/client/item/list/1";
        }

        // Kiểm tra xem sản phẩm đã có trong giỏ chưa
        boolean isExist = false;
        for (BasketBean basket : basketList) {
            if (basket.getId().equals(itemId)) {
                // Đã có -> Tăng số lượng lên 1
                basket.setOrderNum(basket.getOrderNum() + 1);
                isExist = true;
                break;
            }
        }

        // Nếu chưa có -> Thêm mới vào List
        if (!isExist) {
            BasketBean newBasket = new BasketBean();
            newBasket.setId(item.getId());
            newBasket.setName(item.getName());
            newBasket.setStock(item.getStock());
            newBasket.setOrderNum(1); // Mặc định số lượng là 1
            basketList.add(newBasket);
        }

        // Cập nhật lại Session
        session.setAttribute("basketList", basketList);
        
        return "redirect:/client/basket/list"; 
    }

    /**
     * カゴから削除 (Xóa 1 sản phẩm khỏi Giỏ hàng)
     */
    @RequestMapping(path = "/client/basket/delete", method = RequestMethod.POST)
    public String delete(Integer itemId) {
        @SuppressWarnings("unchecked")
        List<BasketBean> basketList = (List<BasketBean>) session.getAttribute("basketList");
        
        if (basketList != null) {
            // Dùng removeIf để xóa phần tử có ID tương ứng (Java 8+)
            basketList.removeIf(basket -> basket.getId().equals(itemId));
            session.setAttribute("basketList", basketList);
        }
        
        return "redirect:/client/basket/list";
    }
}
