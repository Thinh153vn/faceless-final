    /**
     * 買い物かごメニュー 押下
     * Hiển thị danh sách giỏ hàng [cite: 672, 674]
     */
    @RequestMapping(path = "/client/basket/list", method = RequestMethod.GET)
    public String list(Model model) {
        // Lấy giỏ hàng từ session
        List<BasketBean> basketList = (List<BasketBean>) session.getAttribute("basketList");
        
        if (basketList == null) {
            basketList = new ArrayList<>();
        }
        
        // TODO: Viết logic kiểm tra tồn kho và tạo câu thông báo ở đây [cite: 676]

        model.addAttribute("basketList", basketList);
        return "client/basket/list"; // Trả về template [cite: 678]
    }

    /**
     * 買い物かごへ追加ボタン押下
     * Thêm vào giỏ hàng [cite: 649, 650]
     */
    @RequestMapping(path = "/client/basket/add", method = RequestMethod.POST)
    public String add(Integer id) {
        List<BasketBean> basketList = (List<BasketBean>) session.getAttribute("basketList");
        
        // Nếu chưa có giỏ hàng thì tạo mới [cite: 653]
        if (basketList == null) {
            basketList = new ArrayList<>();
        }

        // TODO: Viết logic kiểm tra xem sản phẩm đã có trong basketList chưa[cite: 654]. 
        // Có rồi -> Tăng số lượng. Chưa có -> Thêm mới[cite: 655].

        session.setAttribute("basketList", basketList);
        
        return "redirect:/client/basket/list"; // PRG: Redirect [cite: 656]
    }

    /**
     * 削除ボタン 押下
     * Xóa 1 sản phẩm khỏi giỏ hàng [cite: 660, 661]
     */
    @RequestMapping(path = "/client/basket/delete", method = RequestMethod.POST)
    public String delete(Integer id) {
        // TODO: Lấy basketList từ session, tìm sản phẩm theo ID và xóa [cite: 662]
        return "redirect:/client/basket/list"; // PRG: Redirect [cite: 663]
    }

    /**
     * 買い物かごを空にするボタン 押下
     * Xóa toàn bộ giỏ hàng [cite: 665, 668]
     */
    @RequestMapping(path = "/basket/allDelete", method = RequestMethod.POST)
    public String allDelete() {
        session.removeAttribute("basketList"); // Xóa giỏ hàng khỏi session [cite: 670]
        return "redirect:/client/basket/list"; // PRG: Redirect [cite: 671]
    }
}
