package jp.co.sss.shop.controller.client.review;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Controller;
import org.springframework.ui.Model;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestMethod;
import jakarta.servlet.http.HttpSession;

import jp.co.sss.shop.repository.ReviewRepository;
import jp.co.sss.shop.entity.Review;
import jp.co.sss.shop.bean.UserBean;

import java.sql.Date;

/**
 * レビュー投稿機能のコントローラクラス
 */
@Controller
public class ClientReviewRegistController {

    @Autowired
    ReviewRepository reviewRepository;

    @Autowired
    HttpSession session;

    /**
     * レビュー投稿画面表示
     */
    @RequestMapping(path = "/client/review/regist/input/{itemId}", method = RequestMethod.GET)
    public String input(@PathVariable Integer itemId, Model model) {
        UserBean user = (UserBean) session.getAttribute("user");
        if (user == null) {
            return "redirect:/login";
        }
        
        // Truyền Item ID sang giao diện HTML để khi Submit biết đang đánh giá sản phẩm nào
        model.addAttribute("itemId", itemId);
        return "client/review/regist_input";
    }

    /**
     * レビュー登録処理 (Bỏ qua Check, đăng thẳng vào DB)
     */
    @RequestMapping(path = "/client/review/regist/complete", method = RequestMethod.POST)
    public String complete(Integer itemId, Integer rating, String comment, Model model) {
        UserBean user = (UserBean) session.getAttribute("user");
        if (user == null) {
            return "redirect:/login";
        }

        // Validation cơ bản phía Server
        if (rating == null) {
            model.addAttribute("itemId", itemId);
            model.addAttribute("errorMessage", "評価（星）を選択してください。");
            return "client/review/regist_input";
        }

        Review review = new Review();
        review.setUserId(user.getId());
        review.setItemId(itemId);
        review.setRating(rating);
        review.setComment(comment);
        review.setDeleteFlag(0);
        review.setInsertDate(new Date(System.currentTimeMillis()));
        
        reviewRepository.save(review);

        // Đăng xong, redirect về trang chi tiết của chính sản phẩm đó để khách xem review vừa viết
        return "redirect:/client/item/detail/" + itemId;
    }
}
