package jp.co.sss.shop.controller.client.wishlist;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Controller;
import org.springframework.ui.Model;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestMethod;
import jakarta.servlet.http.HttpSession;

import jp.co.sss.shop.repository.WishlistRepository;
import jp.co.sss.shop.entity.Wishlist;
import jp.co.sss.shop.bean.UserBean; // Giả định class lưu Session User của dự án

import java.sql.Date;

/**
 * お気に入り管理機能のコントローラクラス
 */
@Controller
public class ClientWishlistController {

    @Autowired
    WishlistRepository wishlistRepository;

    @Autowired
    HttpSession session;

    /**
     * お気に入り一覧表示
     */
    @RequestMapping(path = "/client/wishlist/list", method = RequestMethod.GET)
    public String list(Model model) {
        // Lấy thông tin user từ Session (Tên class UserBean có thể thay đổi tùy dự án em)
        UserBean user = (UserBean) session.getAttribute("user");
        if (user == null) {
            return "redirect:/login";
        }

        model.addAttribute("wishlistItems", wishlistRepository.findByUserIdOrderByInsertDateDesc(user.getId()));
        return "client/wishlist/list";
    }

    /**
     * お気に入り追加処理
     */
    @RequestMapping(path = "/client/wishlist/add", method = RequestMethod.POST)
    public String add(Integer itemId) {
        UserBean user = (UserBean) session.getAttribute("user");
        if (user == null) {
            return "redirect:/login";
        }

        // Kiểm tra tránh trùng lặp
        Wishlist existWishlist = wishlistRepository.findByUserIdAndItemId(user.getId(), itemId);
        if (existWishlist == null) {
            Wishlist wishlist = new Wishlist();
            wishlist.setUserId(user.getId());
            wishlist.setItemId(itemId);
            wishlist.setInsertDate(new Date(System.currentTimeMillis()));
            wishlistRepository.save(wishlist);
        }

        return "redirect:/client/wishlist/list";
    }

    /**
     * お気に入り削除処理
     */
    @RequestMapping(path = "/client/wishlist/delete/{id}", method = RequestMethod.POST)
    public String delete(@PathVariable Integer id) {
        UserBean user = (UserBean) session.getAttribute("user");
        if (user != null) {
            wishlistRepository.deleteById(id);
        }
        return "redirect:/client/wishlist/list";
    }
}
