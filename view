<td style="text-align: center;">
    <button type="button" 
            class="favorite-btn"
            th:classappend="${favoriteItemIds != null and favoriteItemIds.contains(item.id)} ? 'active' : ''"
            th:onclick="|toggleFavoriteAjax(this, ${item.id})|">
        <span class="heart-icon" th:text="${favoriteItemIds != null and favoriteItemIds.contains(item.id)} ? '♥' : '♡'"></span>
        お気に入り
    </button>
</td>

css
/* ---- Nút Yêu thích (Trạng thái bình thường - Chưa chọn) ---- */
.favorite-btn {
    background-color: #e0e0e0;
    color: #333;
    padding: 5px 15px;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.3s ease;
}

/* ---- Nút Yêu thích (Trạng thái Active - Đã chọn) ---- */
.favorite-btn.active {
    background-color: #ff9999;
    color: white;
}

/* Hiệu ứng khi rê chuột */
.favorite-btn:hover {
    opacity: 0.8;
}

cuối list.html
<script>
    function toggleFavoriteAjax(buttonElem, itemId) {
        const formData = new URLSearchParams();
        formData.append('itemId', itemId);
        
        // Tìm thẻ span chứa icon trái tim bên trong nút bấm
        const iconSpan = buttonElem.querySelector('.heart-icon');

        // Gọi API ngầm tới Controller
        fetch('http://localhost:55000/shared_shop/client/favorite/toggleAjax', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: formData
        })
        .then(response => response.text())
        .then(data => {
            if (data === 'UNAUTHORIZED') {
                alert('お気に入り機能を利用するにはログインしてください。');
                window.location.href = 'http://localhost:55000/shared_shop/login';
            } else if (data === 'ADDED') {
                // Thêm class 'active' để đổi nền sang màu hồng (#ff9999)
                buttonElem.classList.add('active');
                // Đổi icon sang trái tim đặc
                if(iconSpan) iconSpan.textContent = '♥';
            } else if (data === 'REMOVED') {
                // Xóa class 'active' để trở về màu xám (#e0e0e0)
                buttonElem.classList.remove('active');
                // Đổi icon sang trái tim rỗng
                if(iconSpan) iconSpan.textContent = '♡';
            }
        })
        .catch(error => {
            console.error('Lỗi kết nối AJAX:', error);
        });
    }
    </script>
</body>
</html>
